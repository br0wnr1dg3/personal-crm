# Personal Network CRM — environment template.
# Copy this to .env and fill in your keys.
# (`/personal-crm-setup` and `setup.sh` do this for you.)

# Anthropic API key — needed for Haiku classification of role + seniority.
# Sign up at https://console.anthropic.com/. Cost: ~$1–2 per 5,000 contacts.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Fiber AI API key — needed for company enrichment + email/phone reveal.
# Sign up at https://fiber.ai/. Prospector plan is ~$0.02 per credit.
# You can skip this and still run classification, but ICP queries +
# reveal_contact tools will be unavailable.
FIBER_API_KEY=
FIBER_USD_PER_CREDIT=0.020

# Local SQLite database. Relative paths are resolved against the repo root.
NETCRM_DB_PATH=crm.db
